# Maestro configuration — copy to .env and adjust as needed.
# Every value has a working default; an empty .env is fine.

# Server
MAESTRO_HOST=127.0.0.1
MAESTRO_PORT=8000
MAESTRO_OPEN_BROWSER=true

# Database (SQLite by default; PostgreSQL also works via SQLAlchemy URL)
DATABASE_URL=sqlite:///./data/maestro.db

# Security — set a strong secret in production; when empty, a random
# vault key is generated once and stored in data/.vault.key
SECRET_KEY=

# Shared API token. When set, every /api and /ws request must present it
# (Authorization: Bearer <token>, X-Maestro-Token header, or ?token=). Strongly
# recommended whenever MAESTRO_HOST is not 127.0.0.1. Empty = open local mode.
MAESTRO_API_TOKEN=

# Allow non-Python sandbox interpreters (bash/cmd/powershell) in run_script.
# These run as the Maestro OS user with full filesystem/network access — only
# enable on a trusted, isolated runner. Default (empty/false) = Python only.
MAESTRO_ALLOW_SHELL=false

# Logging
LOG_LEVEL=INFO
DEBUG=false
ENVIRONMENT=production

# CORS (comma-separated origins, only needed for separate dev frontend)
CORS_ORIGINS=http://localhost:5173,http://localhost:8000
