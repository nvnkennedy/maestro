{
  "name": "ssh",
  "display_name": "SSH / Remote target",
  "version": "2.0.0",
  "type": "adapter",
  "description": "Run commands, move files and capture logs on Linux/QNX targets and Windows/RDP boxes over SSH — plus webcam capture and remote-desktop (RDP) screenshot/recording. Powered by your turbossh tool.",
  "powered_by": { "tool": "turbossh", "module": "turbossh" },
  "capabilities": [
    "execute_command",
    "upload_file",
    "download_file",
    "remount_rw",
    "file_exists",
    "list_dir",
    "tail_file",
    "process_status",
    "reboot",
    "capture_journal",
    "capture_slog2info",
    "camera_list",
    "camera_screenshot",
    "camera_record",
    "remote_camera_capture",
    "rdp_screenshot",
    "rdp_record"
  ],
  "capability_groups": {
    "Commands": ["execute_command", "remount_rw", "reboot", "process_status"],
    "Files": ["upload_file", "download_file", "file_exists", "list_dir", "tail_file"],
    "Logs": ["capture_journal", "capture_slog2info"],
    "Camera": ["camera_list", "camera_screenshot", "camera_record", "remote_camera_capture"],
    "RDP capture": ["rdp_screenshot", "rdp_record"]
  },
  "dependencies": ["turbossh>=1.2.16"],
  "entry_point": "adapter:SSHAdapter"
}
